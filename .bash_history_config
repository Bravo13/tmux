# Per-tmux session+window bash history
if [[ -n "$TMUX" ]] && [[ -n "$TMUX_PANE" ]]; then
  # Ask tmux about THIS pane specifically (not the focused one) — avoids
  # tmux-resurrect race where all restored shells see the same active window.
  # #S = session name, #W = window name
  _hist_id=$(tmux display-message -p -t "$TMUX_PANE" '#S-#W')

  # Sanitize: session/window names can contain spaces, slashes, etc.
  _hist_id="${_hist_id//[^A-Za-z0-9_.-]/_}"
  : "${_hist_id:=default}"

  mkdir -p "$HOME/.bash_histories"
  HISTFILE="$HOME/.bash_histories/${_hist_id}"
  HISTSIZE=100000
  HISTFILESIZE=100000

  unset _hist_id
fi
PROMPT_COMMAND="history -a; ${PROMPT_COMMAND}"